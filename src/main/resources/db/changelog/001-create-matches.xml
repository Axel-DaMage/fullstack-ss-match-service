<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="crear-tabla-coincidencias" author="sanosysalvos">
        <createTable tableName="matches">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="id_mascota_perdida" type="BIGINT" nullable="false"/>
            <column name="id_mascota_encontrada" type="BIGINT" nullable="false"/>
            <column name="porcentaje_coincidencia" type="INT"/>
            <column name="estado" type="VARCHAR(20)" nullable="false"/>
            <column name="creado_en" type="TIMESTAMP" nullable="false" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="actualizado_en" type="TIMESTAMP" nullable="false" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </createTable>
        <addIndex tableName="matches" indexName="idx_match_estado">
            <column name="estado"/>
        </addIndex>
    </changeSet>
</databaseChangeLog>