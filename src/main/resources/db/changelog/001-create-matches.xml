<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="create-matches-table" author="sanosysalvos">
        <createTable tableName="matches">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="mascota_perdida_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="mascota_encontrada_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="porcentaje_coincidencia" type="INT"/>
            <column name="estado" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="creado_en" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="actualizado_en" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="matches" indexName="idx_match_estado">
            <column name="estado"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>