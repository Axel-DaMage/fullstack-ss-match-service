<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="create-match-criteria-table" author="sanosysalvos">
        <createTable tableName="match_criteria">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="coincidencia_id" type="BIGINT">
                <constraints foreignKeyName="fk_criteria_match" references="matches(id)" deleteCascade="true"/>
            </column>
            <column name="nombre_criterio" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="puntaje" type="INT"/>
        </createTable>
    </changeSet>
</databaseChangeLog>